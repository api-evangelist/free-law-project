          "info": {
            "name": "Search across CourtListener",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://www.courtlistener.com/api/rest/v4/search/",
            "params": [
              {
                "name": "q",
                "value": "",
